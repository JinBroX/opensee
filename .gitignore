# .gitignore - Cloudflare 版本

# 敏感目录
private/
private/*

# 环境变量
.env
.env.*

# 日志文件
*.log
server.err

# 系统文件
.DS_Store
Thumbs.db

# 依赖（脚本用，不部署）
scripts/node_modules/
server/node_modules/
node_modules/

# 数据库文件（本地运行数据，不入库）
server/data/
*.db
*.db-shm
*.db-wal

# 构建文件（如果需要）
dist/
build/

# 备份
backups/

